{
    "version": 2,
    "builds": [
      {
        "src": "back/index.js",
        "use": "@vercel/node"
      },
      {
        "src": "frontend/package.json",
        "use": "@vercel/static-build"
      }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "back/index.js" },
      { "handle": "filesystem" },
      { "src": "/(.*)", "dest": "/frontend/index.html" }
    ]
  }